# files
File.create("data.txt")                     # Creates a new empty file
File.read("data.txt")                       # Returns all text in the file
File.read("data.txt", line=5)               # Returns only the 5th line
File.stream("large_log.txt")                # Yields lines one by one (better for bigger files)
File.write("data.txt", "Hello")              # Overwrites file with "Hello"
File.write("data.txt", "New Line", mode="append")  # Adds text to the end
File.write("data.txt", "Updated", mode="line", line=2) # Replaces specific line
File.delete("data.txt", mode="trash")       # Moves file to a .trash folder
File.delete("data.txt", mode="perm")        # Permanently deletes the file

# folder
Folder.create("projects/app")               # Creates folder (and parents if missing)
Folder.list("projects")                     # Returns a list of filenames/folders
Folder.is_empty("projects")                 # Returns True if folder has no files
Folder.empty("temp_folder")                 # Deletes all the contents inside the folder
Folder.delete("old_project")                # Deletes the entire directory

# path
Path.exists("test.json")                  # Returns True if path exists
Path.copy("photo.jpg", "backup/photo.jpg")  # Copies file or folder to destination
Path.move("draft.txt", "project/draft.txt")   # Moves/renames file or folder
Path.info("document.pdf")                   # Returns dict with size, type, and dates
Path.find("C:/Users", extensions=".pdf")    # Returns list of all PDFs in a directory
Path.abspath("local_file.txt")              # Returns the full system path

# system
System.cwd()                                # Returns your current working directory
System.cd("C:/Windows")                     # Changes the working directory
System.run("script.py")                     # Runs a Python script or system file
System.exec("echo 'hello'")                 # Executes a terminal command
System.getenv("API_KEY")                    # Gets an environment variable
